# ETL 환경변수 템플릿 — 복사해서 .env 로 사용
# ⚠️ 실제 키는 .env 에만. .env 는 git 에 커밋되지 않음(.gitignore).

# 열린국회정보 (open.assembly.go.kr)
ASSEMBLY_API_KEY=

# 선관위 / 공공데이터포털 (data.go.kr) — Phase 2~3
NEC_API_KEY=
DATA_GO_KR_API_KEY=

# 열린재정 (openapi.openfiscaldata.go.kr) — 분야별 재원배분/결산(세금 쓰임 시각화)
OFD_API_KEY=

# 법안 AI 요약(좋은점/문제점) provider — "ollama"(로컬·무료·무제한) | "gemini"
SUMMARY_PROVIDER=ollama
# 로컬 Ollama (provider=ollama). 먼저: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# Google Gemini (provider=gemini) — 무료 티어는 하루 호출수 제한 작음
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# 적재 대상 DB (backend 와 동일)
DATABASE_URL=postgresql+psycopg://pyosim:pyosim@localhost:5432/pyosim
